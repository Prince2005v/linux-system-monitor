[Unit]
Description=Linux System Monitor Daemon
After=network.target

[Service]
Type=simple
User=root
# Update ExecStart to the absolute path of your python executable and script
ExecStart=/usr/bin/python3 /opt/linux-system-monitor/monitor.py --log-format json
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
